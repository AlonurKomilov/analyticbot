# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Telethon (MTProto) — for fetching channel post history
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=your_phone_number

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=analyticbot_v2
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/analyticbot_v2

# Redis (optional, for caching analysis results)
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-to-a-random-secret

# Analysis defaults
MAX_POSTS_PER_ANALYSIS=500
ANALYSIS_CACHE_TTL_HOURS=24
