{
  "name": "analyticbot-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:user",
    "dev:user": "cd apps/app_analyticbot/user && npm run dev",
    "dev:admin": "cd apps/app_analyticbot/admin && npm run dev",
    "dev:moderator": "cd apps/analyticbot/moderator && npm run dev",
    "dev:public": "cd apps/analyticbot/public && npm run dev",
    "build": "npm run build:user && npm run build:admin && npm run build:moderator && npm run build:public",
    "build:user": "cd apps/app_analyticbot/user && npm run build",
    "build:admin": "cd apps/app_analyticbot/admin && npm run build",
    "build:moderator": "cd apps/analyticbot/moderator && npm run build",
    "build:public": "cd apps/analyticbot/public && npm run build",
    "type-check": "npm run type-check:user && npm run type-check:admin",
    "type-check:user": "cd apps/app_analyticbot/user && npm run type-check",
    "type-check:admin": "cd apps/app_analyticbot/admin && npm run type-check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:user",
    "test:user": "cd apps/app_analyticbot/user && npm run test",
    "install:all": "npm install && cd apps/app_analyticbot/user && npm install && cd ../admin && npm install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@sentry/react": "^8.17.0",
    "@stripe/react-stripe-js": "^2.8.1",
    "@stripe/stripe-js": "^4.7.0",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "idb": "^8.0.3",
    "localforage": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.9.5",
    "react-toastify": "^11.0.5",
    "recharts": "^3.4.1",
    "web-vitals": "^5.1.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@axe-core/react": "^4.8.3",
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^4.6.0",
    "axe-core": "^4.8.3",
    "eslint": "^9.30.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jest-axe": "^8.0.0",
    "jsdom": "^26.1.0",
    "msw": "^2.11.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "terser": "^5.43.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.11",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.2.4"
  }
}
